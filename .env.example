# ------------------------------------------------------------------
# Copy this file to ".env" and fill in your values:
#   cp .env.example .env
# Every value here has a sensible default in src/config.ts, so the
# ONLY thing you strictly must set is HELIUS_API_KEY.
# ------------------------------------------------------------------

# REQUIRED. Get a free key at https://www.helius.dev/
HELIUS_API_KEY=your_helius_api_key_here

# ---- Scan window ----
# How far back each scan looks, in hours.
SCAN_WINDOW_HOURS=24

# ---- Filters (operate on the coin's PEAK / all-time-high market cap) ----
# A coin passes only if its estimated peak market cap is inside this band.
MIN_MARKET_CAP=10000
# Ceiling: exclude coins whose peak went above this. Set to 0 to disable.
MAX_MARKET_CAP=25000
MIN_VOLUME=10000

# Require the token to have an X/Twitter link listed on DEX Screener to pass.
# Cuts out a large share of low-effort/anonymous launches. false by default.
REQUIRE_X_LINK=false

# ---- Peak / ATH estimation (GeckoTerminal — free, no key, no Helius cost) ----
# Pulls historical daily candles to estimate a real peak market cap so the
# MIN/MAX band means "how high it ever got", not "where it is now".
RESOLVE_PEAK_MARKET_CAP=true
# Delay between GeckoTerminal calls. Free tier is ~30/min, so keep >= 2000.
GECKO_DELAY_MS=2100

# Extra token mints to ignore, comma-separated. SOL (wrapped), USDC and USDT
# are ALWAYS ignored automatically; add more here (e.g. mSOL, jitoSOL, etc.).
EXTRA_IGNORED_MINTS=

# ---- Session classification (NA / EU) ----
# IANA timezone. Keep America/Chicago so daylight-savings is handled for you.
TIMEZONE=America/Chicago
# Accepts "10:00 AM" style OR 24h "22:00" style.
NA_START=10:00 AM
NA_END=10:00 PM
EU_START=10:00 PM
EU_END=10:00 AM

# ---- Output ----
OUTPUT_DIR=output

# ---- Rate limiting / retries ----
REQUEST_DELAY_MS=300
MAX_RETRIES=4
RETRY_BACKOFF_MS=1500
DEX_BATCH_SIZE=30

# ---- Helius paging caps (control cost / API usage) ----
MAX_TX_PAGES_PER_WALLET=20
RESOLVE_TOKEN_CREATION_TIME=true
MAX_SIG_PAGES_PER_MINT=5

# ---- Scheduler ----
SCHEDULE_INTERVAL_HOURS=12

# ---- Web dashboard ----
# Port for `npm run serve`.
PORT=3000

# ---- Files ----
WALLETS_FILE=wallets.txt
ATH_STORE_FILE=data/ath-store.json
